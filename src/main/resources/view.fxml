<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="980.0" prefWidth="1480.0"
			style="-fx-background-color: #1f2a37;"
			xmlns="http://javafx.com/javafx/8"
			xmlns:fx="http://javafx.com/fxml/1"
			fx:controller="FXMLController">
	<top>
		<VBox spacing="8.0" style="-fx-padding: 14 16 10 16;">
			<children>
				<Label text="BMS Operations Console (Desktop)" textFill="WHITE">
					<font>
						<Font name="System Bold" size="22.0"/>
					</font>
				</Label>
				<Label fx:id="lblConnection" text="Connecting..." textFill="#d7e2ef"/>
			</children>
		</VBox>
	</top>

	<center>
		<TabPane tabClosingPolicy="UNAVAILABLE">
			<tabs>
				<Tab text="Live Data">
					<content>
						<VBox spacing="12.0" style="-fx-padding: 14;">
							<children>
								<HBox spacing="8.0" alignment="CENTER_LEFT">
									<children>
										<Label text="Display Module" textFill="#d7e2ef"/>
										<ComboBox fx:id="cmbLiveModule" prefWidth="120.0"/>
									</children>
								</HBox>

								<HBox spacing="12.0">
									<children>
										<VBox spacing="4.0" prefWidth="230.0" style="-fx-background-color: #2c3b4d; -fx-padding: 14; -fx-background-radius: 8;">
											<children>
												<Label text="PACK VOLTAGE" textFill="#b8c7d9"/>
												<Label fx:id="lblVoltage" text="0.000 V" textFill="#44d07f">
													<font>
														<Font name="System Bold" size="26.0"/>
													</font>
												</Label>
											</children>
										</VBox>

										<VBox spacing="4.0" prefWidth="230.0" style="-fx-background-color: #2c3b4d; -fx-padding: 14; -fx-background-radius: 8;">
											<children>
												<Label text="PACK CURRENT" textFill="#b8c7d9"/>
												<Label fx:id="lblCurrent" text="0.000 A" textFill="#ffb347">
													<font>
														<Font name="System Bold" size="26.0"/>
													</font>
												</Label>
											</children>
										</VBox>

										<VBox spacing="4.0" prefWidth="230.0" style="-fx-background-color: #2c3b4d; -fx-padding: 14; -fx-background-radius: 8;">
											<children>
												<Label text="SOC" textFill="#b8c7d9"/>
												<Label fx:id="lblSoc" text="0.00 %" textFill="#66b2ff">
													<font>
														<Font name="System Bold" size="26.0"/>
													</font>
												</Label>
											</children>
										</VBox>

										<VBox spacing="4.0" prefWidth="320.0" style="-fx-background-color: #2c3b4d; -fx-padding: 14; -fx-background-radius: 8;">
											<children>
												<Label text="STATUS" textFill="#b8c7d9"/>
												<Label fx:id="lblStatus" text="-" textFill="#f0f4fa" wrapText="true"/>
											</children>
										</VBox>
									</children>
								</HBox>

								<Label fx:id="lblLiveStatusLine" text="Waiting for data..." textFill="#d7e2ef"/>
							</children>
						</VBox>
					</content>
				</Tab>

				<Tab text="Events">
					<content>
						<VBox spacing="10.0" style="-fx-padding: 14;">
							<children>
								<Button fx:id="btnRefreshEvents" text="Refresh Events"/>
								<TableView fx:id="tblEvents" prefHeight="560.0">
									<columns>
										<TableColumn fx:id="colEventTime" text="Timestamp" prefWidth="200.0"/>
										<TableColumn fx:id="colEventModule" text="Module" prefWidth="80.0"/>
										<TableColumn fx:id="colEventSeverity" text="Severity" prefWidth="110.0"/>
										<TableColumn fx:id="colEventCode" text="Code" prefWidth="90.0"/>
										<TableColumn fx:id="colEventMessage" text="Message" prefWidth="760.0"/>
									</columns>
								</TableView>
							</children>
						</VBox>
					</content>
				</Tab>

				<Tab text="Statistics">
					<content>
						<VBox spacing="10.0" style="-fx-padding: 14;">
							<children>
								<HBox spacing="8.0" alignment="CENTER_LEFT">
									<children>
										<Label text="Module" textFill="#d7e2ef"/>
										<ComboBox fx:id="cmbStatsModule" prefWidth="120.0"/>
										<Label text="Time Window" textFill="#d7e2ef"/>
										<ComboBox fx:id="cmbStatsRange" prefWidth="160.0"/>
										<Button fx:id="btnRefreshStats" text="Refresh"/>
									</children>
								</HBox>

								<GridPane hgap="12.0" vgap="8.0">
									<children>
										<Label text="Avg SOC:" textFill="#b8c7d9" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
										<Label fx:id="lblStatAvgSoc" text="-" textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

										<Label text="SOC Range:" textFill="#b8c7d9" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
										<Label fx:id="lblStatSocRange" text="-" textFill="WHITE" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

										<Label text="Voltage Range:" textFill="#b8c7d9" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
										<Label fx:id="lblStatVoltageRange" text="-" textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

										<Label text="Current Range:" textFill="#b8c7d9" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
										<Label fx:id="lblStatCurrentRange" text="-" textFill="WHITE" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

										<Label text="Points:" textFill="#b8c7d9" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
										<Label fx:id="lblStatPoints" text="-" textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

										<Label text="Last Status:" textFill="#b8c7d9" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
										<Label fx:id="lblStatLastStatus" text="-" textFill="WHITE" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
									</children>
								</GridPane>

								<GridPane fx:id="statsChartsGrid" hgap="12.0" vgap="12.0" VBox.vgrow="ALWAYS">
									<children>
										<VBox fx:id="chartCardVoltage" spacing="8.0" style="-fx-background-color: #2c3b4d; -fx-padding: 10; -fx-background-radius: 8;" GridPane.columnIndex="0" GridPane.rowIndex="0">
											<children>
												<HBox spacing="8.0" alignment="CENTER_LEFT">
													<children>
														<Label text="Voltage (V)" textFill="#d7e2ef"/>
														<Button fx:id="btnZoomVoltage" text="Enlarge"/>
													</children>
												</HBox>
												<LineChart fx:id="chartVoltage" prefHeight="260.0" animated="false" createSymbols="false" VBox.vgrow="ALWAYS">
													<xAxis>
														<NumberAxis label="Samples"/>
													</xAxis>
													<yAxis>
														<NumberAxis label="Value"/>
													</yAxis>
												</LineChart>
											</children>
										</VBox>

										<VBox fx:id="chartCardCurrent" spacing="8.0" style="-fx-background-color: #2c3b4d; -fx-padding: 10; -fx-background-radius: 8;" GridPane.columnIndex="1" GridPane.rowIndex="0">
											<children>
												<HBox spacing="8.0" alignment="CENTER_LEFT">
													<children>
														<Label text="Current (A)" textFill="#d7e2ef"/>
														<Button fx:id="btnZoomCurrent" text="Enlarge"/>
													</children>
												</HBox>
												<LineChart fx:id="chartCurrent" prefHeight="260.0" animated="false" createSymbols="false" VBox.vgrow="ALWAYS">
													<xAxis>
														<NumberAxis label="Samples"/>
													</xAxis>
													<yAxis>
														<NumberAxis label="Value"/>
													</yAxis>
												</LineChart>
											</children>
										</VBox>

										<VBox fx:id="chartCardSoc" spacing="8.0" style="-fx-background-color: #2c3b4d; -fx-padding: 10; -fx-background-radius: 8;" GridPane.columnIndex="0" GridPane.rowIndex="1">
											<children>
												<HBox spacing="8.0" alignment="CENTER_LEFT">
													<children>
														<Label text="SOC (%)" textFill="#d7e2ef"/>
														<Button fx:id="btnZoomSoc" text="Enlarge"/>
													</children>
												</HBox>
												<LineChart fx:id="chartSoc" prefHeight="260.0" animated="false" createSymbols="false" VBox.vgrow="ALWAYS">
													<xAxis>
														<NumberAxis label="Samples"/>
													</xAxis>
													<yAxis>
														<NumberAxis label="Value"/>
													</yAxis>
												</LineChart>
											</children>
										</VBox>

										<VBox fx:id="chartCardStatus" spacing="8.0" style="-fx-background-color: #2c3b4d; -fx-padding: 10; -fx-background-radius: 8;" GridPane.columnIndex="1" GridPane.rowIndex="1">
											<children>
												<HBox spacing="8.0" alignment="CENTER_LEFT">
													<children>
														<Label text="Status" textFill="#d7e2ef"/>
														<Button fx:id="btnZoomStatus" text="Enlarge"/>
													</children>
												</HBox>
												<LineChart fx:id="chartStatus" prefHeight="260.0" animated="false" createSymbols="false" VBox.vgrow="ALWAYS">
													<xAxis>
														<NumberAxis label="Samples"/>
													</xAxis>
													<yAxis>
														<NumberAxis label="Value"/>
													</yAxis>
												</LineChart>
											</children>
										</VBox>

										<VBox fx:id="chartCardCells" spacing="8.0" style="-fx-background-color: #2c3b4d; -fx-padding: 10; -fx-background-radius: 8;" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
											<children>
												<HBox spacing="8.0" alignment="CENTER_LEFT">
													<children>
														<Label text="Cell Voltages (mV)" textFill="#d7e2ef"/>
														<Button fx:id="btnZoomCells" text="Enlarge"/>
													</children>
												</HBox>
												<LineChart fx:id="chartCells" prefHeight="260.0" animated="false" createSymbols="false" VBox.vgrow="ALWAYS">
													<xAxis>
														<NumberAxis label="Samples"/>
													</xAxis>
													<yAxis>
														<NumberAxis label="mV"/>
													</yAxis>
												</LineChart>
											</children>
										</VBox>
									</children>
								</GridPane>
							</children>
						</VBox>
					</content>
				</Tab>

				<Tab text="Cell Settings">
					<content>
						<VBox spacing="10.0" style="-fx-padding: 14;">
							<children>
								<HBox spacing="8.0" alignment="CENTER_LEFT">
									<children>
										<Label text="Module" textFill="#d7e2ef"/>
										<ComboBox fx:id="cmbSettingsModule" prefWidth="120.0"/>
										<Label text="Setting" textFill="#d7e2ef"/>
										<ComboBox fx:id="cmbSettingsKey" prefWidth="320.0"/>
										<Label text="Value" textFill="#d7e2ef"/>
										<TextField fx:id="txtSettingsValue" prefWidth="140.0" promptText="numeric value"/>
										<Button fx:id="btnApplySetting" text="Apply"/>
										<Label fx:id="lblSettingsStatus" text="" textFill="#d7e2ef"/>
									</children>
								</HBox>

								<TableView fx:id="tblSettings" prefHeight="560.0">
									<columns>
										<TableColumn fx:id="colSettingLabel" text="Setting" prefWidth="260.0"/>
										<TableColumn fx:id="colSettingUnit" text="Unit" prefWidth="70.0"/>
										<TableColumn fx:id="colSettingMin" text="Min" prefWidth="90.0"/>
										<TableColumn fx:id="colSettingMax" text="Max" prefWidth="90.0"/>
										<TableColumn fx:id="colSettingM1" text="M1" prefWidth="90.0"/>
										<TableColumn fx:id="colSettingM2" text="M2" prefWidth="90.0"/>
										<TableColumn fx:id="colSettingM3" text="M3" prefWidth="90.0"/>
										<TableColumn fx:id="colSettingM4" text="M4" prefWidth="90.0"/>
										<TableColumn fx:id="colSettingWritable" text="Writable" prefWidth="90.0"/>
									</columns>
								</TableView>
							</children>
						</VBox>
					</content>
				</Tab>

				<Tab text="RPi Status">
					<content>
						<VBox spacing="10.0" style="-fx-padding: 14;">
							<children>
								<Label fx:id="lblRpiSummary" text="Loading RPi status..." textFill="#d7e2ef"/>

								<Label text="Ingest Sources" textFill="WHITE"/>
								<TableView fx:id="tblRpiSources" prefHeight="220.0">
									<columns>
										<TableColumn fx:id="colSourceAddr" text="Source" prefWidth="180.0"/>
										<TableColumn fx:id="colSourceLastSeen" text="Last Seen" prefWidth="210.0"/>
										<TableColumn fx:id="colSourceSeconds" text="Seconds Ago" prefWidth="100.0"/>
										<TableColumn fx:id="colSourceOnline" text="Online" prefWidth="90.0"/>
										<TableColumn fx:id="colSourceAccepted" text="Accepted" prefWidth="100.0"/>
										<TableColumn fx:id="colSourceLastModule" text="Last Module" prefWidth="110.0"/>
									</columns>
								</TableView>

								<Label text="Modules Freshness" textFill="WHITE"/>
								<TableView fx:id="tblRpiModules" prefHeight="220.0">
									<columns>
										<TableColumn fx:id="colModuleId" text="Module" prefWidth="120.0"/>
										<TableColumn fx:id="colModuleLastSeen" text="Last Seen" prefWidth="250.0"/>
										<TableColumn fx:id="colModuleSeconds" text="Seconds Ago" prefWidth="120.0"/>
										<TableColumn fx:id="colModuleOnline" text="Online" prefWidth="100.0"/>
									</columns>
								</TableView>
							</children>
						</VBox>
					</content>
				</Tab>
			</tabs>
		</TabPane>
	</center>
</BorderPane>
