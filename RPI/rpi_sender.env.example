# Host API endpoint
HOST_API_URL=http://192.168.1.100:8090/api/ingest

# Serial configuration
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=115200
SERIAL_TIMEOUT=1.0

# TinyBMS S516 active polling (binary request/response)
TINYBMS_ACTIVE_POLL=true
TINYBMS_POLL_INTERVAL_SEC=2.0
TINYBMS_COMMAND_TIMEOUT_SEC=0.5

# Sender behavior
DEFAULT_MODULE_ID=1
HEARTBEAT_INTERVAL_SEC=10
POST_TIMEOUT_SEC=3
RETRY_BACKOFF_SEC=1.0
MAX_QUEUE_LINES=2000
# For single-pack setups where incoming lines do not contain a reliable module id.
FORCE_DEFAULT_MODULE_ID=false
# Diagnostics: log every Nth ignored UART line (0 disables).
LOG_UNKNOWN_EVERY_N=20
LOG_LEVEL=INFO
