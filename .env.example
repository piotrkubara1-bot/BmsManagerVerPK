# BMS host stack configuration template
# Copy to .env (optional) and/or set these variables in your shell.

# API service
BMS_API_PORT=8090
BMS_STOP_EXISTING=1
BMS_STARTUP_RETRIES=15
BMS_STARTUP_DELAY_SEC=1

# Simulator
BMS_SIM_COUNT=120
BMS_SIM_INTERVAL_MS=1000

# UI
WEB_UI_PORT=8088
GUI_API_BASE=http://127.0.0.1:8090
GUI_INPUT_MODE=api

# Database (used by service defaults/overrides)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bms
DB_USER=root
DB_PASSWORD=
